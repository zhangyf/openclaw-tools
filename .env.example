# OpenClaw 自动化工具集 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ====================
# Tavily API 配置
# ====================
# 获取地址: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ====================
# 腾讯云 COS 配置
# ====================
# 获取地址: https://console.cloud.tencent.com/cam/capi
TENCENT_COS_SECRET_ID=your_cos_secret_id
TENCENT_COS_SECRET_KEY=your_cos_secret_key
TENCENT_COS_BUCKET=your_bucket_name
TENCENT_COS_REGION=ap-singapore

# ====================
# AI API 配置
# ====================
# DeepSeek API (用于 Token 统计)
# 获取地址: https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=your_deepseek_api_key

# Moonshot API (可选)
MOONSHOT_API_KEY=your_moonshot_api_key

# ====================
# Telegram 配置
# ====================
# Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 群聊 ID (负数为群组)
TELEGRAM_GROUP_ID=-5149902750

# 个人聊天 ID
TELEGRAM_PERSONAL_ID=8331827497

# ====================
# 应用配置
# ====================
# 工作目录
WORKSPACE_DIR=/home/zhangyufeng/.openclaw/workspace

# 简报保存目录
BRIEFINGS_DIR=${WORKSPACE_DIR}/briefings

# 备份目录
BACKUP_DIR=${WORKSPACE_DIR}/backup-reports

# Token 报告目录
TOKEN_REPORTS_DIR=${WORKSPACE_DIR}/token-reports

# ====================
# 脚本配置
# ====================
# 战争简报 - 激进模式 (有消息就报)
WAR_BRIEFING_AGGRESSIVE_MODE=true

# 财经数据源偏好 (tavily|manual)
FINANCE_DATA_SOURCE=tavily

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# Token 统计保留天数
TOKEN_STATS_RETENTION_DAYS=30

# ====================
# 日志配置
# ====================
# 日志级别 (debug|info|warn|error)
LOG_LEVEL=info

# 日志文件路径
LOG_FILE=${WORKSPACE_DIR}/logs/openclaw-tools.log

# ====================
# 测试配置
# ====================
# 测试模式 (true|false)
TEST_MODE=false

# 模拟数据目录
MOCK_DATA_DIR=${WORKSPACE_DIR}/test/mock-data

# ====================
# 高级配置
# ====================
# Go 脚本超时时间 (秒)
GO_SCRIPT_TIMEOUT=300

# Node.js 脚本超时时间 (秒)
NODE_SCRIPT_TIMEOUT=600

# 搜索超时时间 (秒)
SEARCH_TIMEOUT=30

# 最大重试次数
MAX_RETRIES=3

# ====================
# 通知配置
# ====================
# 成功通知 (true|false)
NOTIFY_ON_SUCCESS=true

# 失败通知 (true|false)
NOTIFY_ON_FAILURE=true

# 警告通知 (true|false)
NOTIFY_ON_WARNING=true