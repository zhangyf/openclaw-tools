# 忽略环境变量文件
.env
*.env

# 忽略日志文件
*.log
logs/

# 忽略临时文件
tmp/
temp/

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略Node.js模块
node_modules/

# 忽略Go模块缓存
go/pkg/
go/bin/

# 忽略备份文件
*.bak
*.backup

# 忽略个人笔记文件（中文文件名）
*.md
!WORKFLOW_AUTO.md